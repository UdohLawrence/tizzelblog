<!DOCTYPE html>
<html class="h-full">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>
      {{ title }} | Tizzel Blog - Musings of an Educator, Developer, and Tech Enthusiast
    </title>
    <meta
      name="description"
      content="Tizzel is a blog that focuses on sharing knowledge and insights on technology, education, and personal development."
    />
    <meta
      name="keywords"
      content="technology, education, personal development, programming, web development, software development, software engineering, computer science, computer programming, coding, teaching, learning, self-improvement, self-development, self-help, motivation, inspiration, productivity, career, work, job, employment, business, entrepreneurship, leadership, management, marketing, sales, finance, accounting, economics, psychology, sociology, philosophy, science, engineering, mathematics, arts, humanities, social sciences, natural sciences, formal sciences, applied sciences, information technology, information systems, computer information systems, information science, data science, big data, artificial intelligence, machine learning, deep learning, neural networks, natural language processing, computer vision, robotics, automation, internet of things, blockchain, cryptocurrency, digital marketing, social media, search engine optimization, search engine marketing, content marketing, email marketing, affiliate marketing, influencer marketing, network marketing, online marketing, offline marketing, mobile marketing, video marketing, audio marketing, podcasting, blogging, vlogging, microblogging, social networking, social bookmarking, social sharing, social media marketing, social media optimization, social media advertising, social media management, social media monitoring, social media analytics, social media engagement, social media influence, social media strategy, social media policy, social media guidelines, social media ethics, social media etiquette, social media law, social media regulation, social media compliance, social media security, social media privacy, social media reputation, social media crisis, social media disaster, social media recovery, social media branding, social media marketing, social media advertising, social media management, social media monitoring, social media analytics, social media engagement, social media influence, social media strategy, social media policy, social media guidelines, social media ethics, social media etiquette, social media law, social media regulation, social media compliance, social media security, social media privacy, social media reputation, social media crisis, social media disaster, social media recovery, social media branding, social media marketing, social media advertising, social media management, social media monitoring, social media analytics, social media engagement, social media influence, social media strategy, social media policy, social media guidelines, social media ethics, social media etiquette, social media law, social media regulation, social media compliance, social media security, social media privacy, social media reputation, social media crisis, social media disaster, social media recovery, social media branding, social"
    />
    @vite(['resources/css/app.css', 'resources/js/app.js'])
    @stack('dumper')
  </head>
  <body class="bg-gray-50 flex flex-col min-h-full">
<nav class="bg-white border-gray-200 dark:bg-gray-900">
  <div class="max-w-7xl flex flex-wrap items-center justify-between mx-auto p-4">
    <a href="/" class="flex items-center space-x-3 rtl:space-x-reverse">
      {{--  <img src="/public/logo.svg" alt="Site Logo" class="w-16 h-16" />  --}}
      <span class="self-center text-2xl font-semibold whitespace-nowrap dark:text-white">Tizzel</span>
    </a>
    <button data-collapse-toggle="navbar-default" type="button" class="inline-flex items-center p-2 w-10 h-10 justify-center text-sm text-gray-500 rounded-lg md:hidden hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-gray-200 dark:text-gray-400 dark:hover:bg-gray-700 dark:focus:ring-gray-600" aria-controls="navbar-default" aria-expanded="false">
        <span class="sr-only">Open main menu</span>
        <svg class="w-5 h-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 17 14">
            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1 1h15M1 7h15M1 13h15"/>
        </svg>
    </button>
    <div class="hidden w-full md:block md:w-auto" id="navbar-default">
      <ul class="font-medium flex flex-col p-4 md:p-0 mt-4 border border-gray-100 rounded-lg bg-gray-50 md:flex-row md:space-x-8 rtl:space-x-reverse md:mt-0 md:border-0 md:bg-white dark:bg-gray-800 md:dark:bg-gray-900 dark:border-gray-700">
        <li>
          <a href="#" class="block py-2 px-3 text-white bg-blue-700 rounded-sm md:bg-transparent md:text-blue-700 md:p-0 dark:text-white md:dark:text-blue-500" aria-current="page">Home</a>
        </li>
        <li>
          <a href="#" class="block py-2 px-3 text-gray-900 rounded-sm hover:bg-gray-100 md:hover:bg-transparent md:border-0 md:hover:text-blue-700 md:p-0 dark:text-white md:dark:hover:text-blue-500 dark:hover:bg-gray-700 dark:hover:text-white md:dark:hover:bg-transparent">About</a>
        </li>
        <li>
          <a href="#" class="block py-2 px-3 text-gray-900 rounded-sm hover:bg-gray-100 md:hover:bg-transparent md:border-0 md:hover:text-blue-700 md:p-0 dark:text-white md:dark:hover:text-blue-500 dark:hover:bg-gray-700 dark:hover:text-white md:dark:hover:bg-transparent">Services</a>
        </li>
        <li>
          <a href="#" class="block py-2 px-3 text-gray-900 rounded-sm hover:bg-gray-100 md:hover:bg-transparent md:border-0 md:hover:text-blue-700 md:p-0 dark:text-white md:dark:hover:text-blue-500 dark:hover:bg-gray-700 dark:hover:text-white md:dark:hover:bg-transparent">Pricing</a>
        </li>
        <li>
          <a href="#" class="block py-2 px-3 text-gray-900 rounded-sm hover:bg-gray-100 md:hover:bg-transparent md:border-0 md:hover:text-blue-700 md:p-0 dark:text-white md:dark:hover:text-blue-500 dark:hover:bg-gray-700 dark:hover:text-white md:dark:hover:bg-transparent">Contact</a>
        </li>
      </ul>
    </div>
  </div>
</nav>
    <main class="grow">
      {{{ await $slots.main() }}}
    </main>
    <script src="../../../../node_modules/flowbite/dist/flowbite.min.js"></script>
  </body>
</html>
